{
    "name": "lphenom/storage",
    "description": "LPhenom Storage — filesystem storage abstraction for PHP and KPHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["lphenom", "storage", "filesystem", "kphp"],
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "LPhenom\\Storage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Storage\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}

